{# Pasek filtrów dla list rozwijanych kart (.acct). Czysty JS, bez zależności.
   Filtruje po tekście (summary) ORAZ po severity (chipy z licznikami). Dodatkowo:
   - przyciski "Rozwiń/Zwiń wszystkie" (operują tylko na widocznych kartach),
   - skrót "/" fokusuje szukajkę,
   - beforeprint rozwija wszystkie karty (zwinięte <details> nie drukują treści),
   - otwiera i podświetla kartę wskazaną w #hash (głębokie linki z raportu summary). #}
<div class="ag-filterbar" data-agfilter>
  <input class="filter-search" type="search" placeholder="🔍 Szukaj (nazwa, sygnał, rola…)  —  skrót: /" aria-label="Szukaj">
  <span class="filter-chip active" data-sev="critical">critical <b class="chip-n"></b></span>
  <span class="filter-chip active" data-sev="high">high <b class="chip-n"></b></span>
  <span class="filter-chip active" data-sev="medium">medium <b class="chip-n"></b></span>
  <span class="filter-chip active" data-sev="low">low <b class="chip-n"></b></span>
  <span class="filter-chip active" data-sev="info">info <b class="chip-n"></b></span>
  <button class="filter-btn" type="button" data-act="expand" title="Rozwiń wszystkie widoczne karty">⊞ rozwiń</button>
  <button class="filter-btn" type="button" data-act="collapse" title="Zwiń wszystkie karty">⊟ zwiń</button>
  <span class="filter-count"></span>
</div>
<script>
(function () {
  // currentScript jest dostępny tylko podczas synchronicznego wykonania — łapiemy pasek od razu,
  // ale resztę inicjalizujemy po DOMContentLoaded: karty .acct są w dokumencie PONIŻEJ paska,
  // więc w chwili wykonania skryptu jeszcze nie istnieją (inline script biegnie w trakcie parsowania).
  var bar = document.currentScript.previousElementSibling;
  while (bar && !bar.hasAttribute('data-agfilter')) { bar = bar.previousElementSibling; }
  if (!bar) return;
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  function init() {
  var search = bar.querySelector('.filter-search');
  var chips = Array.prototype.slice.call(bar.querySelectorAll('.filter-chip'));
  var counter = bar.querySelector('.filter-count');
  // Karty = wszystkie .acct w dokumencie (jedna lista per raport).
  var cards = Array.prototype.slice.call(document.querySelectorAll('details.acct'));

  function sevOf(card) {
    var m = (card.className.match(/sev-(\w+)/) || [])[1];
    return m || 'info';
  }

  // Liczniki na chipach: ile kart ma daną ocenę (stałe — liczone raz).
  var sevTotals = {};
  cards.forEach(function (card) {
    var s = sevOf(card);
    sevTotals[s] = (sevTotals[s] || 0) + 1;
  });
  chips.forEach(function (c) {
    var n = c.querySelector('.chip-n');
    if (n) n.textContent = sevTotals[c.dataset.sev] || 0;
  });

  function apply() {
    var q = (search.value || '').trim().toLowerCase();
    var allowed = {};
    chips.forEach(function (c) { if (c.classList.contains('active')) allowed[c.dataset.sev] = true; });
    var shown = 0;
    cards.forEach(function (card) {
      var okSev = allowed[sevOf(card)];
      var okTxt = !q || card.textContent.toLowerCase().indexOf(q) !== -1;
      var visible = okSev && okTxt;
      card.classList.toggle('hidden', !visible);
      if (visible) shown++;
    });
    if (counter) counter.textContent = shown + ' / ' + cards.length;
  }
  chips.forEach(function (c) { c.addEventListener('click', function () { c.classList.toggle('active'); apply(); }); });
  search.addEventListener('input', apply);
  apply();

  // Rozwiń/zwiń: rozwijamy tylko widoczne (po filtrze), zwijamy wszystkie.
  function setOpen(open, onlyVisible) {
    cards.forEach(function (card) {
      if (open && onlyVisible && card.classList.contains('hidden')) return;
      card.open = open;
    });
  }
  bar.querySelector('[data-act="expand"]').addEventListener('click', function () { setOpen(true, true); });
  bar.querySelector('[data-act="collapse"]').addEventListener('click', function () { setOpen(false, false); });

  // Skrót "/" — szybki fokus szukajki (jak na GitHubie).
  document.addEventListener('keydown', function (e) {
    if (e.key === '/' && !/INPUT|TEXTAREA|SELECT/.test(document.activeElement.tagName)) {
      e.preventDefault();
      search.focus();
    }
  });

  // Druk: zwinięte <details> nie renderują treści — rozwijamy wszystko, po druku przywracamy.
  var openedForPrint = [];
  window.addEventListener('beforeprint', function () {
    openedForPrint = cards.filter(function (c) { return !c.open; });
    openedForPrint.forEach(function (c) { c.open = true; });
  });
  window.addEventListener('afterprint', function () {
    openedForPrint.forEach(function (c) { c.open = false; });
    openedForPrint = [];
  });

  // Głębokie linki z raportu summary: #obj-<id> -> otwórz, podświetl i wycentruj kartę.
  function openFromHash() {
    if (!location.hash) return;
    var el = document.getElementById(decodeURIComponent(location.hash.slice(1)));
    if (!el || !el.classList.contains('acct')) return;
    el.classList.remove('hidden');
    el.open = true;
    el.classList.remove('targeted');
    void el.offsetWidth; /* restart animacji przy ponownym kliknięciu */
    el.classList.add('targeted');
    el.scrollIntoView({ block: 'center' });
  }
  window.addEventListener('hashchange', openFromHash);
  openFromHash();
  }
})();
</script>
