{# Pasek filtrów dla list rozwijanych kart (.acct). Czysty JS, bez zależności.
   Filtruje po tekście (summary) ORAZ po severity (chipy z licznikami). Dodatkowo:
   - przyciski "Rozwiń/Zwiń wszystkie" (operują tylko na widocznych kartach),
   - skrót "/" fokusuje szukajkę,
   - beforeprint rozwija wszystkie karty (zwinięte <details> nie drukują treści),
   - otwiera i podświetla kartę wskazaną w #hash (głębokie linki z raportu summary). #}
<div class="ag-filterbar" data-agfilter>
  <input class="filter-search" type="search" placeholder="{{ tr('tmpl.filter.search_placeholder') }}" aria-label="{{ tr('tmpl.filter.search_aria') }}">
  <button type="button" class="filter-chip active" data-sev="critical" aria-pressed="true">critical <b class="chip-n"></b></button>
  <button type="button" class="filter-chip active" data-sev="high" aria-pressed="true">high <b class="chip-n"></b></button>
  <button type="button" class="filter-chip active" data-sev="medium" aria-pressed="true">medium <b class="chip-n"></b></button>
  <button type="button" class="filter-chip active" data-sev="low" aria-pressed="true">low <b class="chip-n"></b></button>
  <button type="button" class="filter-chip active" data-sev="info" aria-pressed="true">info <b class="chip-n"></b></button>
  <button class="filter-btn" type="button" data-act="expand" title="{{ tr('tmpl.filter.expand_title') }}">⊞ {{ tr('tmpl.filter.expand') }}</button>
  <button class="filter-btn" type="button" data-act="collapse" title="{{ tr('tmpl.filter.collapse_title') }}">⊟ {{ tr('tmpl.filter.collapse') }}</button>
  <span class="filter-count"></span>
</div>
<script>
(function () {
  // currentScript jest dostępny tylko podczas synchronicznego wykonania — łapiemy pasek od razu,
  // ale resztę inicjalizujemy po DOMContentLoaded: karty .acct są w dokumencie PONIŻEJ paska,
  // więc w chwili wykonania skryptu jeszcze nie istnieją (inline script biegnie w trakcie parsowania).
  var bar = document.currentScript.previousElementSibling;
  while (bar && !bar.hasAttribute('data-agfilter')) { bar = bar.previousElementSibling; }
  if (!bar) return;
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  function init() {
  var search = bar.querySelector('.filter-search');
  var chips = Array.prototype.slice.call(bar.querySelectorAll('.filter-chip'));
  var counter = bar.querySelector('.filter-count');
  // Karty ograniczamy do tego MODUŁU (najbliższy .ag-module) — w raporcie połączonym są trzy
  // listy (zakładki Konta/Grupy/Aplikacje), każdy filtr musi działać tylko na swojej.
  // Fallback do całego dokumentu, gdyby paska nie owijał .ag-module (dawne standalone).
  var scope = bar.closest('.ag-module') || document;
  var cards = Array.prototype.slice.call(scope.querySelectorAll('details.acct'));

  function sevOf(card) {
    var m = (card.className.match(/sev-(\w+)/) || [])[1];
    return m || 'info';
  }

  // Liczniki na chipach: ile kart ma daną ocenę (stałe — liczone raz).
  var sevTotals = {};
  cards.forEach(function (card) {
    var s = sevOf(card);
    sevTotals[s] = (sevTotals[s] || 0) + 1;
  });
  chips.forEach(function (c) {
    var n = c.querySelector('.chip-n');
    if (n) n.textContent = sevTotals[c.dataset.sev] || 0;
  });

  // Aktywny "facet" z kafelków (np. guest/active/nomfa/highrisk) — pojedynczy, null = brak.
  var facet = null;

  function facetOf(card) {
    return (card.getAttribute('data-facet') || '').toLowerCase().split(/\s+/);
  }

  function apply() {
    var q = (search.value || '').trim().toLowerCase();
    var allowed = {};
    chips.forEach(function (c) { if (c.classList.contains('active')) allowed[c.dataset.sev] = true; });
    var shown = 0;
    cards.forEach(function (card) {
      var okSev = allowed[sevOf(card)];
      var okTxt = !q || card.textContent.toLowerCase().indexOf(q) !== -1;
      var okFacet = !facet || facetOf(card).indexOf(facet) !== -1;
      var visible = okSev && okTxt && okFacet;
      card.classList.toggle('hidden', !visible);
      if (visible) shown++;
    });
    if (counter) counter.textContent = shown + ' / ' + cards.length;
  }
  chips.forEach(function (c) {
    c.addEventListener('click', function () {
      c.classList.toggle('active');
      c.setAttribute('aria-pressed', c.classList.contains('active') ? 'true' : 'false');
      apply();
    });
  });
  search.addEventListener('input', apply);

  // --- Interaktywne KAFELKI (na górze modułu) — klik filtruje rozpiskę poniżej.
  //   data-filter-sev=X    -> pokaż tylko severity X (ponowny klik = przywróć wszystkie),
  //   data-filter-facet=Y  -> pokaż tylko karty z facetem Y (ponowny klik = wyczyść),
  //   data-filter-clear    -> wyczyść wszystko (wszystkie severity, brak facetu, pusta szukajka).
  var tiles = Array.prototype.slice.call(
    scope.querySelectorAll('[data-filter-sev],[data-filter-facet],[data-filter-clear]')
  );
  function markTile(active) {
    tiles.forEach(function (tl) { tl.classList.toggle('tile-active', tl === active); });
  }
  function setChips(only) {
    // only=null -> wszystkie aktywne; only='high' -> tylko 'high' aktywny.
    chips.forEach(function (c) {
      var on = !only || c.dataset.sev === only;
      c.classList.toggle('active', on);
      c.setAttribute('aria-pressed', on ? 'true' : 'false');
    });
  }
  function afterTile() {
    apply();
    // Kafelki są NAD rozpiską — przewiń do paska filtra, żeby od razu było widać efekt.
    if (bar.scrollIntoView) bar.scrollIntoView({ block: 'start' });
  }
  tiles.forEach(function (tl) {
    tl.addEventListener('click', function () {
      if (tl.hasAttribute('data-filter-clear')) {
        facet = null; setChips(null); search.value = ''; markTile(null); afterTile(); return;
      }
      var sev = tl.getAttribute('data-filter-sev');
      if (sev) {
        var isolated = chips.length && chips.every(function (c) {
          return c.dataset.sev === sev ? c.classList.contains('active') : !c.classList.contains('active');
        });
        facet = null;
        if (isolated) { setChips(null); markTile(null); } else { setChips(sev); markTile(tl); }
        afterTile(); return;
      }
      var f = tl.getAttribute('data-filter-facet');
      if (f) {
        if (facet === f) { facet = null; markTile(null); }
        else { facet = f; setChips(null); markTile(tl); }
        afterTile(); return;
      }
    });
  });

  apply();

  // Rozwiń/zwiń: rozwijamy tylko widoczne (po filtrze), zwijamy wszystkie.
  function setOpen(open, onlyVisible) {
    cards.forEach(function (card) {
      if (open && onlyVisible && card.classList.contains('hidden')) return;
      card.open = open;
    });
  }
  bar.querySelector('[data-act="expand"]').addEventListener('click', function () { setOpen(true, true); });
  bar.querySelector('[data-act="collapse"]').addEventListener('click', function () { setOpen(false, false); });

  // Skrót "/" — szybki fokus szukajki (jak na GitHubie).
  document.addEventListener('keydown', function (e) {
    if (e.key === '/' && !/INPUT|TEXTAREA|SELECT/.test(document.activeElement.tagName)) {
      // W raporcie połączonym jest kilka filtrów (zakładki) — fokusujemy szukajkę TYLKO tej,
      // której zakładka jest aktywna. Standalone (brak .ag-tabpanel) -> zawsze.
      var panel = bar.closest('.ag-tabpanel');
      if (panel && !panel.classList.contains('active')) return;
      e.preventDefault();
      search.focus();
    }
  });

  // Druk: zwinięte <details> nie renderują treści — rozwijamy wszystko, po druku przywracamy.
  var openedForPrint = [];
  window.addEventListener('beforeprint', function () {
    openedForPrint = cards.filter(function (c) { return !c.open; });
    openedForPrint.forEach(function (c) { c.open = true; });
  });
  window.addEventListener('afterprint', function () {
    openedForPrint.forEach(function (c) { c.open = false; });
    openedForPrint = [];
  });

  // Głębokie linki z raportu summary: #obj-<id> -> otwórz, podświetl i wycentruj kartę.
  function openFromHash() {
    if (!location.hash) return;
    var el = document.getElementById(decodeURIComponent(location.hash.slice(1)));
    if (!el || !el.classList.contains('acct')) return;
    el.classList.remove('hidden');
    el.open = true;
    el.classList.remove('targeted');
    void el.offsetWidth; /* restart animacji przy ponownym kliknięciu */
    el.classList.add('targeted');
    el.scrollIntoView({ block: 'center' });
  }
  window.addEventListener('hashchange', openFromHash);
  openFromHash();
  }
})();
</script>
