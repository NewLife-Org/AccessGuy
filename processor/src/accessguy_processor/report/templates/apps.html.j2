{% from '_sevbar.html.j2' import sevbar %}<!doctype html>
<html lang="{{ lang }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ tr('tmpl.apps.html_title') }}</title>
<style>{{ css }}</style>
</head>
<body>
<header class="ag-header">
  <pre class="ag-logo" aria-label="AccessGuy logo">{{ access_guy_logo }}
{{ access_guy_text }}</pre>
  <div class="ag-brand">AccessGuy</div>
  <div class="ag-sub">{{ tr('tmpl.module.brand_sub') }} <strong>{{ tr('community.module.apps') }}</strong></div>
  <div class="ag-meta">
    {{ tr('tmpl.meta.tenant') }}: <strong>{{ dataset.tenant.display_name }}</strong> ·
    {{ tr('tmpl.meta.apps') }}: <strong>{{ dataset.applications | length }}</strong> ·
    {{ tr('tmpl.meta.mode') }}: <strong>{{ dataset.scan_context.auth_mode }}</strong> ·
    {{ tr('tmpl.meta.scan') }}: <strong>{{ dataset.generated_at.isoformat() }}</strong>
  </div>
</header>

{% include '_apps_body.html.j2' %}

<footer class="ag-footer">
  AccessGuy · {{ tr('tmpl.footer.role.apps') }} · {{ tr('tmpl.footer.author_rendered', at=rendered_at) }}
  <br><span class="muted">{{ tr('tmpl.footer.methodology_apps') }}</span>
  <div class="ag-links"><a href="{{ linkedin }}">LinkedIn</a> · <a href="{{ github }}">GitHub</a> · <a href="{{ youtube }}">YouTube</a></div>
  <pre class="ag-tattoo" aria-label="Daniel NewLife Budyn">{{ tattoo_logo }}</pre>
</footer>
</body>
</html>
